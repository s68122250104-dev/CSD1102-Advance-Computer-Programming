<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ssru.example1.workfx1.CalculatorController">

    <Label text="Calculator" style="-fx-font-size:18"/>

    <GridPane hgap="10" vgap="10">

        <Label text="First operand:"
               GridPane.rowIndex="0"
               GridPane.columnIndex="0"/>

        <TextField fx:id="num1"
                   GridPane.rowIndex="0"
                   GridPane.columnIndex="1"/>


        <Label text="Second operand:"
               GridPane.rowIndex="1"
               GridPane.columnIndex="0"/>

        <TextField fx:id="num2"
                   GridPane.rowIndex="1"
                   GridPane.columnIndex="1"/>

    </GridPane>

    <HBox spacing="10">

        <Button text="Add" onAction="#add"/>
        <Button text="Subtract" onAction="#sub"/>
        <Button text="Multiply" onAction="#mul"/>
        <Button text="Divide" onAction="#div"/>

    </HBox>

    <HBox spacing="10">

        <Label text="Result:"/>
        <TextField fx:id="result"/>

    </HBox>

</VBox>
